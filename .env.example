# Local development: copy to `.env` and fill in values. Do not commit `.env`.
# Production: set the same keys on your host (e.g. Vercel → Environment Variables).

# Public Supabase (anon) — required for auth and Edge Function invokes from the browser.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# Optional: Stripe *test* publishable key for a small “test mode” banner on Buy credits / Dashboard.
# Does not replace server secrets: checkout uses `sk_test_…` / webhook signing via Supabase secrets & Admin.
# Use `pk_test_…` from Stripe Dashboard (Developers → API keys) when Test mode is on.
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Supabase Edge Functions (set in Supabase Dashboard → Edge Functions → secrets, not in Vite):
# - STRIPE_SECRET_KEY or app_settings (sk_test_… for test, sk_live_… for live)
# - STRIPE_WEBHOOK_SECRET for stripe-webhook signature verification
# Webhook URL (Stripe Dashboard → Webhooks): https://<project-ref>.supabase.co/functions/v1/stripe-webhook

# Optional storefront analytics (see Admin Settings UI)
# VITE_GA_MEASUREMENT_ID=
# VITE_PLAUSIBLE_DOMAIN=
