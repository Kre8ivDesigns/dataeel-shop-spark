# Local development: copy to `.env` and fill in values. Do not commit `.env`.
# Production: set the same keys on your host (e.g. Vercel → Environment Variables).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# Optional: label for Equibase late-changes section (must match EQUIBASE_LATE_CHANGES_BRN on Supabase)
# VITE_EQUIBASE_LATE_CHANGES_TRACK_LABEL=Keeneland

# Optional storefront analytics (see Admin Settings UI)
# VITE_GA_MEASUREMENT_ID=
# VITE_PLAUSIBLE_DOMAIN=
